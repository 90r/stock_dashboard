{
  "name": "korea-memory-price-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run test/*.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy",
    "deploy:cloudflare": "node scripts/deploy-cloudflare.mjs",
    "backfill:local-upload": "node scripts/backfill-local-upload.mjs",
    "db:migrate:local": "wrangler d1 migrations apply korea_memory_monitor --local",
    "db:migrate:remote": "wrangler d1 migrations apply korea_memory_monitor --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260517.0",
    "@playwright/test": "^1.54.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
